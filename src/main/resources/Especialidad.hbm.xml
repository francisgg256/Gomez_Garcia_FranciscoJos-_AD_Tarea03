<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="es.damdi.francisco.dominio.Especialidad" table="ESPECIALIDAD">
        <id name="idEspecialidad" column="ESPECIALIDAD">
            <generator class="assigned"/>
        </id>
        <property name="nombre" column="NOMBRE_ESPE" type="string"/>
    </class>
</hibernate-mapping>